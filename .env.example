# Copy to .env in a private runtime only. Do not commit real values.

# Optional data-source credentials for future scripts/adapters
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-application-credentials.json
DATAFORSEO_LOGIN=example-login
DATAFORSEO_PASSWORD=example-password
# Free Google API key for PageSpeed Insights / CrUX field data (site audits)
PAGESPEED_API_KEY=example-api-key

# Optional report delivery integrations
GOOGLE_DRIVE_FOLDER_ID=example-folder-id
